#!/bin/sh
# Pre-commit: fmt + vet + lint (fast — no tests)
# Works on Linux, macOS, and Windows (Git Bash).
set -e

echo "── fmt ──────────────────────────────────────"
go fmt ./...

echo "── vet ──────────────────────────────────────"
go vet ./...

echo "── lint ─────────────────────────────────────"
golangci-lint run ./...

echo "✅ Pre-commit checks passed"
